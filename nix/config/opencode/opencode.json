          "go get*": "ask",
          "composer require*": "ask",
          "bundle add*": "ask",
          "mix deps.get*": "ask",
          "git add*": "ask",
          "git commit*": "ask",
          "git restore*": "ask",
          "git checkout*": "ask",
          "git switch*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git stash*": "ask",
          "git rebase*": "ask",
