          "npm run check*": "allow",
          "pnpm test*": "allow",
          "pnpm run test*": "allow",
          "pnpm run lint*": "allow",
          "pnpm run build*": "allow",
          "pnpm run typecheck*": "allow",
          "pnpm run check*": "allow",
          "bun test*": "allow",
          "bun run test*": "allow",
          "bun run lint*": "allow",
          "bun run build*": "allow",
          "bun run typecheck*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "python -m unittest*": "allow",
          "ruff check*": "allow",
          "ruff format --check*": "allow",
          "black --check*": "allow",
          "mypy*": "allow",
          "pyright*": "allow",
          "cargo test*": "allow",
          "cargo check*": "allow",
          "cargo build*": "allow",
          "cargo clippy*": "allow",
          "cargo fmt -- --check*": "allow",
          "go test*": "allow",
          "go build*": "allow",
