{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.5",
  "small_model": "opencode/gpt-5-nano",
  "disabled_providers": [
    "openrouter"
  ],
  "instructions": [
    "~/.config/opencode/instructions/shell_strategy.md",
    "./instructions/tool_preference.md"
  ],
  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": true
    }
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "build": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "permission": {
        "bash": {
          "*": "ask",
          "pwd*": "allow",
          "ls*": "allow",
          "find*": "allow",
          "cat*": "allow",
          "head*": "allow",
          "tail*": "allow",
          "wc*": "allow",
          "stat*": "allow",
          "file*": "allow",
          "grep*": "allow",
          "rg*": "allow",
          "awk*": "allow",
          "sed*": "allow",
          "sort*": "allow",
          "uniq*": "allow",
          "cut*": "allow",
          "xargs*": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git diff --staged*": "allow",
          "git rev-parse --show-toplevel*": "allow",
          "git branch --show-current*": "allow",
          "git ls-files*": "allow",
          "npm test*": "allow",
          "npm run test*": "allow",
          "npm run lint*": "allow",
          "npm run build*": "allow",
          "npm run typecheck*": "allow",
          "npm run check*": "allow",
          "pnpm test*": "allow",
          "pnpm run test*": "allow",
          "pnpm run lint*": "allow",
          "pnpm run build*": "allow",
          "pnpm run typecheck*": "allow",
          "pnpm run check*": "allow",
          "bun test*": "allow",
          "bun run test*": "allow",
          "bun run lint*": "allow",
          "bun run build*": "allow",
          "bun run typecheck*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "python -m unittest*": "allow",
          "ruff check*": "allow",
          "ruff format --check*": "allow",
          "black --check*": "allow",
          "mypy*": "allow",
          "pyright*": "allow",
          "cargo test*": "allow",
          "cargo check*": "allow",
          "cargo build*": "allow",
          "cargo clippy*": "allow",
          "cargo fmt -- --check*": "allow",
          "go test*": "allow",
          "go build*": "allow",
          "go vet*": "allow",
          "gofmt -l*": "allow",
          "phpunit*": "allow",
          "composer test*": "allow",
          "composer lint*": "allow",
          "npm install*": "ask",
          "npm add*": "ask",
          "pnpm install*": "ask",
          "pnpm add*": "ask",
          "yarn add*": "ask",
          "yarn install*": "ask",
          "bun add*": "ask",
          "pip install*": "ask",
          "poetry add*": "ask",
          "cargo add*": "ask",
          "go get*": "ask",
          "composer require*": "ask",
          "bundle add*": "ask",
          "mix deps.get*": "ask",
          "git add*": "ask",
          "git commit*": "ask",
          "git restore*": "ask",
          "git checkout*": "ask",
          "git switch*": "ask",
          "git reset*": "ask",
          "git clean*": "ask",
          "git stash*": "ask",
          "git rebase*": "ask",
          "git merge*": "ask",
          "git pull*": "ask",
          "git push*": "ask",
          "rm*": "ask",
          "mv*": "ask",
          "cp*": "ask",
          "chmod*": "ask",
          "chown*": "ask",
          "mkdir*": "ask",
          "rmdir*": "ask",
          "docker*": "ask",
          "docker-compose*": "ask",
          "curl*": "ask",
          "wget*": "ask",
          "bash*": "ask",
          "sh*": "ask",
          "zsh*": "ask",
          "fish*": "ask"
        }
      }
    },
    "explore": {
      "model": "opencode-go/minimax-m2.5",
      "description": "Read-only local discovery agent. Finds relevant files, patterns, interfaces, and conventions in the codebase.",
      "tools": {
        "bash": false,
        "edit": false,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "websearch": false,
        "webfetch": false,
        "task": false
      }
    },
    "librarian": {
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.5",
      "prompt": "{file:./prompts/librarian.md}",
      "description": "Research subagent for external libraries, APIs, frameworks, and related local code context. Use to gather source-grounded findings, compare options, inspect local usage patterns, and return concise structured research for the calling agent.",
      "tools": {
        "bash": false,
        "edit": false,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "websearch": true,
        "webfetch": true,
        "task": false
      }
    },
    "code-reviewer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "variant": "high",
      "prompt": "{file:./prompts/code-reviewer.md}",
      "description": "Validation agent with two modes: `pre-flight` for reviewing execution plans before worker spawn, and `final` for reviewing completed code after implementation. Use to catch task decomposition issues, dependency/interface mismatches, correctness bugs, security risks, performance problems, and architectural drift. Returns approval status, issues by severity, and the next required action.",
      "tools": {
        "read": true,
        "list": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "edit": false,
        "webfetch": false,
        "task": false
      }
    },
    "chat": {
      "description": "Conversational Read-only Q&A agent for direct user queries. Provides clear explanations, general guidance, and quick answers like ChatGPT/Gemini.",
      "prompt": "{file:./prompts/chat.md}",
      "tools": {
        "bash": false,
        "edit": false,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "websearch": true,
        "webfetch": true,
        "task": false
      }
    },
    "worker": {
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.5",
      "description": "Focused coding agent for a single bounded task. Implements changes, validates locally, and reports what changed.",
      "tools": {
        "read": true,
        "list": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "edit": true,
        "webfetch": false,
        "task": false
      },
      "permission": {
        "bash": {
          "*": "ask",
          "pwd*": "allow",
          "ls*": "allow",
          "find*": "allow",
          "cat*": "allow",
          "head*": "allow",
          "tail*": "allow",
          "wc*": "allow",
          "stat*": "allow",
          "file*": "allow",
