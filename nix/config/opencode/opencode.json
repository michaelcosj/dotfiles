{
  "$schema": "https://opencode.ai/config.json",
  "model": "fireworks-ai/accounts/fireworks/routers/glm-5-fast",
  "small_model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
  "enabled_providers": [
    "fireworks-ai",
    "anthropic",
    "github-copilot",
  ],
  "instructions": [
    "./instructions/agent_etiquette.md"
  ],
  "plugin": [
    "cc-safety-net",
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_API_KEY}"
      ],
      "enabled": false
    }
  },
  "permission": {
    "bash": {
      "btca *": "allow"
    }
  },
  "agent": {
    "compaction": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "general": {
      "permission": {
        "question": "allow"
      }
    },
    "plan": {
      "model": "fireworks-ai/accounts/fireworks/routers/glm-5-fast",
      "permission": {
        "task": {
          "worker": "deny"
        }
      }
    },
    "build": {
      "model": "fireworks-ai/accounts/fireworks/routers/glm-5-fast"
    },
    "explore": {
      "model": "github-copilot/gpt-5.4-mini",
      "description": "Read-only local discovery agent. Finds relevant files, patterns, interfaces, and conventions in the codebase.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "edit": "deny",
        "websearch": "deny",
        "webfetch": "deny",
        "task": "deny"
      }
    },
    "librarian": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.4-mini",
      "prompt": "{file:./prompts/librarian.md}",
      "description": "Research subagent for external libraries, APIs, frameworks, and related local code context. Use to gather source-grounded findings, compare options, inspect local usage patterns, and return concise structured research for the calling agent.",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "task": "deny",
        "bash": {
          "*": "deny",
          "btca *": "allow"
        }
      }
    },
    "code-reviewer": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "prompt": "{file:./prompts/code-reviewer.md}",
      "description": "Validation agent with two modes: `pre-flight` for reviewing execution plans before worker spawn, and `final` for reviewing completed code after implementation. Use to catch task decomposition issues, dependency/interface mismatches, correctness bugs, security risks, performance problems, and architectural drift. Returns approval status, issues by severity, and the next required action.",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "edit": "deny",
        "webfetch": "deny",
        "task": "deny"
      }
    },
    "worker": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
      "description": "Focused coding agent for a single bounded task. Implements changes, validates locally, and reports what changed.",
      "permission": {
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "edit": "allow",
        "webfetch": "deny",
        "task": "deny"
      }
    }
  },
  "provider": {
    "fireworks-ai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Fireworks",
      "options": {
        "apiKey": "{env:FIREWORKS_AI_API_KEY}",
        "baseURL": "https://api.fireworks.ai/inference/v1"
      },
      "models": {
        "accounts/fireworks/routers/glm-5-fast": {
          "name": "GLM 5 (fast)"
        },
        "accounts/fireworks/routers/kimi-k2p5-turbo": {
          "name": "Kimi K2.5 (Turbo)"
        }
      }
    }
  }
}
